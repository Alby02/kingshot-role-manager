FROM ghcr.io/astral-sh/uv:latest AS uv_base

FROM python:3.12-slim AS builder
COPY --from=uv_base /uv /uvx /bin/

WORKDIR /app

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# Dependency layer: only changes when pyproject/lock changes
COPY pyproject.toml uv.lock ./
RUN uv venv /opt/venv \
	&& UV_PROJECT_ENVIRONMENT=/opt/venv uv sync --frozen --no-dev --no-install-project

FROM python:3.12-slim AS runtime

WORKDIR /app

ENV PATH="/opt/venv/bin:$PATH"
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY --from=builder /opt/venv /opt/venv
COPY . .

CMD ["python", "main.py"]
